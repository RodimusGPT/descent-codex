---
import { PARTS } from "../lib/parts";
import { devHref, partHref, withBase } from "../lib/routes";

type Props = {
  currentPath: string;
};

const { currentPath } = Astro.props;
const currentPart = PARTS.find((part) => currentPath.includes(`/parts/${part.slug}`));
const isReview = currentPath.startsWith("/dev");
---

<a class="skip-link" href="#main-content">Skip to content</a>
<header class="site-header">
  <a class="site-brand" href={withBase("/")} aria-label="Descent home">
    <span class="site-brand__mark">D</span>
    <span>Descent</span>
  </a>
  <nav class="site-header__nav" aria-label="Primary navigation">
    <a href={withBase("/")} aria-current={currentPath === "/" ? "page" : undefined}>Home</a>
    <a
      href={currentPart ? partHref(currentPart.slug) : partHref("0-hook")}
      aria-current={currentPart ? "page" : undefined}
    >
      Parts
    </a>
    <a href={devHref()} aria-current={isReview ? "page" : undefined}>Review</a>
  </nav>
  <button class="theme-toggle" type="button" data-theme-toggle aria-pressed="false">
    Theme
  </button>
</header>

<script is:inline>
  const toggle = document.querySelector("[data-theme-toggle]");
  const applyThemeLabel = () => {
    const isDark = document.documentElement.dataset.theme === "dark";
    toggle?.setAttribute("aria-pressed", String(isDark));
    if (toggle) {
      toggle.textContent = isDark ? "Light" : "Dark";
    }
  };

  toggle?.addEventListener("click", () => {
    const nextTheme = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    document.documentElement.dataset.theme = nextTheme;
    localStorage.setItem("descent-theme", nextTheme);
    applyThemeLabel();
  });

  applyThemeLabel();
</script>
