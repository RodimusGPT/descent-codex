---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SANDBOXES } from "../../lib/sandboxes";
---

<BaseLayout title="Interactive Review">
  <main class="site-shell review-shell" id="main-content">
    <header class="review-hero">
      <div>
        <p class="eyebrow">Interactive review</p>
        <h1>Sandboxes</h1>
      </div>
      <a href="/parts/0-hook">Open the descent</a>
    </header>

    <section class="review-overview" aria-labelledby="review-overview-title">
      <div>
        <h2 id="review-overview-title">Review path</h2>
        <p>
          Open any standalone interactive sandbox. Part 1 sandboxes are now included for M4 review.
        </p>
      </div>
      <nav class="review-grid" aria-label="Interactive sandboxes">
        {
          SANDBOXES.map((sandbox) => (
            <a href={sandbox.path}>
              <span>Part {sandbox.part}</span>
              <strong>{sandbox.label}</strong>
            </a>
          ))
        }
      </nav>
    </section>
  </main>
</BaseLayout>
