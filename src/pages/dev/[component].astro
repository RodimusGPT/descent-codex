---
import AttentionFan from "../../components/viz/AttentionFan";
import BatchingTimeline from "../../components/viz/BatchingTimeline";
import EmbeddingSpace from "../../components/viz/EmbeddingSpace";
import FloatExploder from "../../components/viz/FloatExploder";
import MemoryBudget from "../../components/viz/MemoryBudget";
import MoERouter from "../../components/viz/MoERouter";
import PagedAttention from "../../components/viz/PagedAttention";
import PrefillDecode from "../../components/viz/PrefillDecode";
import QKVMultiHead from "../../components/viz/QKVMultiHead";
import QuantizationSlider from "../../components/viz/QuantizationSlider";
import SamplingPlayground from "../../components/viz/SamplingPlayground";
import SpeculativeDecoding from "../../components/viz/SpeculativeDecoding";
import Tokenizer from "../../components/viz/Tokenizer";
import TransformerStack from "../../components/viz/TransformerStack";
import WeightZoom from "../../components/viz/WeightZoom";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SANDBOXES } from "../../lib/sandboxes";

export function getStaticPaths() {
  return SANDBOXES.map((sandbox) => ({
    params: { component: sandbox.slug },
    props: { component: sandbox.slug },
  }));
}

const { component } = Astro.props;
const activeSandbox = SANDBOXES.find((sandbox) => sandbox.slug === component) ?? SANDBOXES[0];
---

<BaseLayout title={`Review: ${activeSandbox.title}`}>
  <main class="site-shell review-shell" id="main-content">
    <header class="review-hero">
      <div>
        <p class="eyebrow">Interactive review</p>
        <h1>{activeSandbox.label}</h1>
      </div>
      <a href="/dev/">All sandboxes</a>
    </header>

    <div class="review-layout">
      <aside class="review-sidebar" aria-label="Checkpoint sandboxes">
        <p class="review-sidebar__label">Interactive sandboxes</p>
        <nav>
          {
            SANDBOXES.map((sandbox) => (
              <a
                aria-current={sandbox.slug === activeSandbox.slug ? "page" : undefined}
                href={sandbox.path}
              >
                <span>Part {sandbox.part}</span>
                <strong>{sandbox.label}</strong>
              </a>
            ))
          }
        </nav>
      </aside>

      <section class="review-workspace" aria-label={`${activeSandbox.label} sandbox`}>
        {component === "tokenizer" ? <Tokenizer client:load /> : null}
        {component === "embedding" ? <EmbeddingSpace client:load /> : null}
        {component === "stack" ? <TransformerStack client:load /> : null}
        {component === "attention" ? <AttentionFan client:load /> : null}
        {component === "qkv" ? <QKVMultiHead client:load /> : null}
        {component === "moe" ? <MoERouter client:load /> : null}
        {component === "sampling" ? <SamplingPlayground client:load /> : null}
        {component === "weight-zoom" ? <WeightZoom client:load /> : null}
        {component === "float" ? <FloatExploder client:load /> : null}
        {component === "quant" ? <QuantizationSlider client:load /> : null}
        {component === "memory-budget" ? <MemoryBudget client:load /> : null}
        {component === "prefill" ? <PrefillDecode client:load /> : null}
        {component === "batching" ? <BatchingTimeline client:load /> : null}
        {component === "paged-attention" ? <PagedAttention client:load /> : null}
        {component === "speculative" ? <SpeculativeDecoding client:load /> : null}
      </section>
    </div>
  </main>
</BaseLayout>
