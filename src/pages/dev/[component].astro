---
import AttentionFan from "../../components/viz/AttentionFan";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [
    {
      params: { component: "attention" },
      props: { component: "attention" },
    },
  ];
}

const { component } = Astro.props;
---

<BaseLayout title={`Dev: ${component}`}>
  <main class="site-shell dev-sandbox">
    <p class="eyebrow">Sandbox</p>
    <h1>{component}</h1>
    {component === "attention" ? <AttentionFan client:load /> : null}
  </main>
</BaseLayout>
