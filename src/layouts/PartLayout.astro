---
import ProgressRail from "../components/scroll/ProgressRail";
import { PARTS } from "../lib/parts";
import { partHref } from "../lib/routes";
import BaseLayout from "./BaseLayout.astro";

type Props = {
  partIndex: number;
  question: string;
  title: string;
};

const { partIndex, question, title } = Astro.props;
const currentPart = PARTS.find((part) => part.index === partIndex) ?? PARTS[0];
const previousPart = PARTS.find((part) => part.index === partIndex - 1);
const nextPart = PARTS.find((part) => part.index === partIndex + 1);
---

<BaseLayout title={title} description={question}>
  <ProgressRail client:load currentPart={partIndex} parts={PARTS} />
  <main class="part-shell" id="main-content">
    <header class="part-hero">
      <div>
        <p class="part-kicker">Part {partIndex}</p>
        <h1>{title}</h1>
      </div>
      <p class="part-question">{question}</p>
    </header>
    <nav class="part-map" aria-label="Descent parts">
      {
        PARTS.map((part) => (
          <a
            aria-current={part.slug === currentPart.slug ? "page" : undefined}
            href={partHref(part.slug)}
          >
            <span>{part.index}</span>
            <strong>{part.title}</strong>
          </a>
        ))
      }
    </nav>
    <article class="part-content">
      <slot />
    </article>
    <nav class="part-pager" aria-label="Adjacent parts">
      {
        previousPart ? (
          <a href={partHref(previousPart.slug)}>
            <span>Previous</span>
            <strong>
              {previousPart.index}. {previousPart.title}
            </strong>
          </a>
        ) : (
          <span />
        )
      }
      {
        nextPart ? (
          <a href={partHref(nextPart.slug)}>
            <span>Next</span>
            <strong>
              {nextPart.index}. {nextPart.title}
            </strong>
          </a>
        ) : (
          <span />
        )
      }
    </nav>
  </main>
</BaseLayout>
