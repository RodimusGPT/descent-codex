{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["src/*"]
    },
    "strict": true,
    "types": ["astro/client"]
  },
  "include": [".astro/types.d.ts", "src/**/*.ts", "src/**/*.tsx", "test/**/*.ts"],
  "exclude": ["dist"]
}
